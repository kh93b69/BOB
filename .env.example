# Скопируй этот файл в .env и заполни значения.
# .env в git не коммитится — см. .gitignore.

# Токен бота от BotFather
TELEGRAM_BOT_TOKEN=

# Telegram user_id админа (можно несколько через запятую)
ADMIN_USER_IDS=494349908

# IANA-таймзона. Для проекта БОБ — Asia/Almaty (UTC+5)
DEFAULT_TIMEZONE=Asia/Almaty

# Путь к файлу расписания (относительно корня репо)
SCHEDULE_FILE=schedule.yaml

# Уровень логирования: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
